# ──────────────────────────────────────────────────────────────────────────────
# AURA-WEAR  —  Environment Configuration
# cp .env.example .env   then fill in the blanks
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (used by docker-compose and the app) ──────────────────────────
POSTGRES_DB=aurawear
POSTGRES_USER=aura
POSTGRES_PASSWORD=aurapassword

# Overridden automatically inside docker-compose (points to the 'db' service).
# For local dev without Docker, change host to localhost:
DATABASE_URL=postgresql+asyncpg://aura:aurapassword@localhost:5432/aurawear

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret:  python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-super-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Email / SMTP (FR-54/55/56) ────────────────────────────────────────────────
# Leave SMTP_USER / SMTP_PASS blank to skip sending (activity is logged to console).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
ADMIN_EMAIL=

# ── AI (Google Gemini) ────────────────────────────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
# Gemini 1.5 Flash is free tier — no billing required for low usage
GEMINI_API_KEY=

# ── n8n AI Workflow (optional — Gemini is called directly if key is set) ──────
# When running via docker-compose, this is set automatically to http://n8n:5678/webhook/aura-chat
# For local dev (n8n running separately): http://localhost:5678/webhook/aura-chat
N8N_WEBHOOK_URL=http://localhost:5678/webhook/aura-chat

# ── Security (FR-45) ──────────────────────────────────────────────────────────
# Set to "true" only when running behind an HTTPS reverse proxy (nginx/Caddy/etc.)
ENFORCE_HTTPS=false
