# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aurawear

# JWT secret — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-super-secret-key

# Optional: n8n webhook URL for real LLM calls
N8N_WEBHOOK_URL=
